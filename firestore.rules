rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function verifiedEmailUser() {
      return signedIn()
        && request.auth.token.email_verified == true
        && request.auth.token.email is string;
    }

    function normalizedEmail(email) {
      return email is string ? email.lower() : '';
    }

    function isAdmin() {
      return verifiedEmailUser()
        && exists(/databases/$(database)/documents/platform/config)
        && get(/databases/$(database)/documents/platform/config).data.adminEmail is string
        && normalizedEmail(get(/databases/$(database)/documents/platform/config).data.adminEmail)
          == normalizedEmail(request.auth.token.email);
    }

    function isConfiguredAdminEmail(email) {
      return email is string
        && exists(/databases/$(database)/documents/platform/config)
        && get(/databases/$(database)/documents/platform/config).data.adminEmail is string
        && normalizedEmail(email)
          == normalizedEmail(get(/databases/$(database)/documents/platform/config).data.adminEmail);
    }

    match /users/{userId} {
      allow create: if signedIn() && request.auth.uid == userId;
      allow read: if signedIn()
        && (request.auth.uid == userId || !isConfiguredAdminEmail(resource.data.email) || isAdmin());
      allow update: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if signedIn() && request.auth.uid == userId;
    }

    match /tutorProfiles/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId
        || !isConfiguredAdminEmail(resource.data.email)
        || isAdmin();
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if signedIn() && request.auth.uid == userId;
    }

    match /bookings/{bookingId} {
      allow create: if signedIn()
        && request.resource.data.studentId == request.auth.uid
        && request.auth.uid in request.resource.data.participantIds;
      allow read, update: if signedIn() && (request.auth.uid in resource.data.participantIds || isAdmin());
      allow delete: if false;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.studentId == request.auth.uid;
    }

    match /platform/{docId} {
      allow read: if true;
      allow create: if verifiedEmailUser()
        && request.resource.data.adminEmail is string
        && normalizedEmail(request.resource.data.adminEmail) == normalizedEmail(request.auth.token.email);
      allow update: if verifiedEmailUser()
        && resource.data.adminEmail is string
        && normalizedEmail(resource.data.adminEmail) == normalizedEmail(request.auth.token.email)
        && request.resource.data.adminEmail is string
        && normalizedEmail(request.resource.data.adminEmail) == normalizedEmail(resource.data.adminEmail);
      allow delete: if verifiedEmailUser()
        && resource.data.adminEmail is string
        && normalizedEmail(resource.data.adminEmail) == normalizedEmail(request.auth.token.email);
    }

    match /platformUpdates/{updateId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /courseRequests/{requestId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.requesterUserId == request.auth.uid
        && request.resource.data.requesterRole in ['student', 'tutor']
        && request.resource.data.courseCode is string
        && request.resource.data.courseName is string
        && request.resource.data.details is string
        && request.resource.data.status == 'open';
      allow update, delete: if isAdmin();
    }

    match /courseRequestInterests/{interestId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.tutorUserId == request.auth.uid
        && request.resource.data.requestId is string
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'tutor';
      allow delete: if isAdmin()
        || (signedIn() && resource.data.tutorUserId == request.auth.uid);
      allow update: if isAdmin();
    }

    match /userNotifications/{notificationId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (
          signedIn()
          && resource.data.userId == request.auth.uid
          && request.resource.data.keys().hasOnly([
            'userId',
            'title',
            'message',
            'createdAt',
            'createdByEmail',
            'active',
            'readAt',
            'clearedAt',
          ])
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.title == resource.data.title
          && request.resource.data.message == resource.data.message
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.createdByEmail == resource.data.createdByEmail
          && request.resource.data.active is bool
          && (
            request.resource.data.readAt == resource.data.readAt
            || request.resource.data.readAt == null
            || request.resource.data.readAt == request.time
          )
          && (
            request.resource.data.clearedAt == resource.data.clearedAt
            || request.resource.data.clearedAt == null
            || request.resource.data.clearedAt == request.time
          )
        );
    }
  }
}
